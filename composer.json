{
    "name": "omisai/php-creditonline",
    "description": "PHP package to interact with the CreditOnline API",
    "license": "MIT",
    "keywords": [
        "creditonline",
        "php",
        "sdk",
        "rest",
        "api"
    ],
    "homepage": "https://github.com/omisai-tech/php-creditonline",
    "authors": [
        {
            "name": "Sándor Gergely Bornemisza",
            "email": "bornemisza@omisai.com",
            "homepage": "https://omisai.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^4.3",
        "laravel/pint": "^1.27"
    },
    "scripts": {
        "test": "pest --colors=always",
        "lint": [
            "pint --parallel"
        ],
        "test:lint": [
            "pint --parallel --test"
        ]
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "autoload": {
        "psr-4": {
            "Omisai\\CreditOnline\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Omisai\\CreditOnline\\Tests\\": "tests/"
        }
    }
}
